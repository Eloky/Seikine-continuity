# ens-gateway env contract. Copy to .env (gitignored) and fill. NEVER commit .env.
#
# Secret: the gateway signing key. Its PUBLIC address must be registered in the
# resolver's `signers` map (it is the constructor signer 0xc04F4c30Cae99354BD2B6F5C099D73b94726c7b7).
GATEWAY_SIGNER_PK=0x...

# Sepolia RPC the gateway reads positions through.
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/<key>

# Deployed SeikinePositionResolver — bound into the signature digest.
RESOLVER_ADDRESS=0x71d7882A2d38Df2d5F10d01f703CFB81EDC73EB0

# Deployed SeikineLendingController — the live position source.
CONTROLLER_ADDRESS=0xaAb9801E5f3a0789BC272f24250b16Cc1975527A

# HTTP port (default 8080).
PORT=8080
